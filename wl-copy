        dinos[6] = new Troodonte(map);
        dinos[7] = new Troodonte(map);
        dinos[8] = new Troodonte(map);
        dinos[9] = new Tiranossauro(map);

        Player player = new Player(map);

        while(true) {
            map.renderMap();
            int input = 0;
            System.out.println("Escolha para onde se mover: ");
